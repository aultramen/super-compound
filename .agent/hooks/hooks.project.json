{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \".agent/hooks/suggest-compact.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Suggest /sc-pause at logical intervals based on tool call count"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \".agent/hooks/pre-compact.js\""
          }
        ],
        "description": "Save STATE.md snapshot before context compaction"
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \".agent/hooks/session-end.js\""
          }
        ],
        "description": "Persist session state and prompt for knowledge compounding"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \".agent/hooks/stop-check.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Warn about console.log and sensitive-looking output after each response"
      }
    ]
  }
}
